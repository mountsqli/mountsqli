{
  "name": "@mountsqli/compiler",
  "version": "0.6.1",
  "type": "module",
  "description": "MountSQLI QueryPlan IR, SQL dialect abstraction, and query optimizer",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mountsqli/schema": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "keywords": [
    "mountsqli",
    "sql",
    "orm",
    "typescript",
    "type-safe",
    "sqlite",
    "postgres",
    "mysql",
    "database"
  ],
  "homepage": "https://github.com/mountsqli/mountsqli#readme",
  "bugs": {
    "url": "https://github.com/mountsqli/mountsqli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mountsqli/mountsqli.git"
  },
  "author": "shekhsahebali",
  "license": "MIT",
  "engines": {
    "node": ">=22.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
