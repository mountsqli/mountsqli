{
  "name": "@mountsqli/driver-mysql",
  "version": "0.6.0",
  "type": "module",
  "description": "MountSQLI MySQL driver (mysql2) with ? parameter pass-through",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mountsqli/compiler": "workspace:*",
    "@mountsqli/driver": "workspace:*",
    "@mountsqli/schema": "workspace:*",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
